# ── qconduit environment config ────────────────────────────────────────────────
# Copy this file to .env and fill real values

# Budget — total USD the scheduler may spend before throttling kicks in
TOTAL_BUDGET_USD=5.0

# Redis (default works with docker-compose)
REDIS_URL=redis://localhost:6379

# API / Grafana URLs
API_BASE_URL=http://localhost:8000
GRAFANA_URL=http://localhost:3000/d/qconduit
PROMETHEUS_URL=https://localhost:9090

# ── Provider API keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
GEMINI_API_KEY=your_gemini_api_key
META_API_KEY=your_meta_key
OPENAI_API_KEY=your_openai_api_key
SARVAM_API_KEY=your_sarvam_api_key

ELEVENLABS_DEFAULT_VOICE=21m00Tcm4TlvDq8ikWAM

# ── Ollama (local, no key needed) ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text