{
  "_comment": "Scheduler infers priority from action type. User can override via priority_override field.",
  "priority_rules": {
    "high": {
      "actions": [
        "stt",
        "tts"
      ],
      "reason": "Real-time voice interactions \u2014 user is waiting, latency matters"
